rules_version = '2';

// Dare to Care - Firestore security rules.
// Reads require login; sensitive writes are restricted by role; audit is
// append-only; certificates are created by the course site (anonymous auth).

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return isSignedIn() && hasUserDoc() && userRole() == 'admin';
    }
    function isStaff() {
      return isSignedIn() && hasUserDoc() && (userRole() == 'admin' || userRole() == 'officeManager');
    }
    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /metadata/setup {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSelf(userId) || isAdmin();
      allow delete: if false;
    }

    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    match /submissions/{submissionId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create, delete: if isStaff();
      allow update: if isSignedIn();
    }

    match /audit/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /certificates/{certId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.source == 'course-site';
      allow update: if isStaff();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
